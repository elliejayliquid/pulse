# Pulse environment variables
# Copy this file to .env and fill in your values.
# For per-persona secrets, copy to personas/<name>/.env instead.

# Telegram bot token (get one from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Cloud API keys (only need the one matching your provider type)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
